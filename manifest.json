{
  "manifest_version": 3,
  "name": "Rhythm",
  "version": "1.0.0",
  "description": "A lightweight, offline-first schedule discipline and wellbeing assistant.",
  "permissions": ["storage", "alarms", "notifications", "offscreen"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Rhythm",
    "default_icon": {
      "16": "icon128.png",
      "32": "icon128.png",
      "48": "icon128.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icon128.png",
    "32": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "offline_enabled": true
}
