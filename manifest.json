{
  "manifest_version": 3,
  "name": "Rhythm – Wellness Companion",
  "short_name": "Rhythm",
  "version": "1.5.0",
  "description": "Water, posture, eye-rest and break reminders plus a Pomodoro focus timer. A lightweight, offline wellness companion.",
  "permissions": ["storage", "alarms", "notifications", "offscreen"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Rhythm",
    "default_icon": {
      "16": "icon128.png",
      "32": "icon128.png",
      "48": "icon128.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icon128.png",
    "32": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  },
  "offline_enabled": true,
  "minimum_chrome_version": "120"
}
